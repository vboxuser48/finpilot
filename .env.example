# Core environment configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database URLs (PostgreSQL preferred, SQLite fallback shown)
DATABASE_URL=postgresql://finpilot:finpilot@localhost:5432/finpilot
ASYNC_DATABASE_URL=postgresql+asyncpg://finpilot:finpilot@localhost:5432/finpilot

# Security
JWT_SECRET_KEY=replace-with-long-access-secret
JWT_REFRESH_SECRET_KEY=replace-with-long-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Default admin seed
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
